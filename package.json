{
  "name": "nikita-pichugin-static",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "npm run content:verify:runtime && npm run museum:sync && npm run site:renditions && npm run health && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "postbuild": "node scripts/prune-dist.mjs && node scripts/verify-built-site.mjs",
    "preview": "astro preview --host 0.0.0.0",
    "lint": "ASTRO_TELEMETRY_DISABLED=1 astro check && npm run content:verify:runtime",
    "test": "vitest run tests/*.test.mjs",
    "test:e2e": "playwright test",
    "import:content": "node scripts/import-content.mjs",
    "classify:source": "node scripts/classify-live-content.mjs",
    "audit:content-diff": "node scripts/compare-live-content.mjs",
    "audit:source": "node scripts/audit-source.mjs",
    "content:refresh": "node scripts/refresh-museum-catalog.mjs && node scripts/verify-museum-catalog.mjs && npm run museum:sync",
    "content:verify": "node scripts/verify-museum-catalog.mjs",
    "content:verify:runtime": "node scripts/verify-museum-catalog.mjs --runtime",
    "museum:sync": "node scripts/sync-museum-public-assets.mjs",
    "site:renditions": "node scripts/generate-site-renditions.mjs",
    "verify:site": "node scripts/verify-built-site.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "health": "node scripts/health.mjs"
  },
  "dependencies": {
    "astro": "latest",
    "cheerio": "latest",
    "he": "latest",
    "sharp": "latest"
  },
  "devDependencies": {
    "@astrojs/check": "latest",
    "@playwright/test": "latest",
    "@types/he": "latest",
    "@types/node": "latest",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "exifr": "^7.1.3",
    "typescript": "latest",
    "vitest": "latest"
  }
}
