---
import "./tour.css";

interface Props {
  frameSrc: string;
  frameTitle: string;
  kicker: string;
  heading: readonly [string, string];
  summary: string;
  backHref: string;
}

const { frameSrc, frameTitle, kicker, heading, summary, backHref } = Astro.props;
---

<section class="tour-shell" data-tour-shell data-back-href={backHref} aria-labelledby="tour-title">
  <a class="tour-back" href={backHref} aria-label="Вернуться на сайт">
    <span aria-hidden="true">←</span>
    <span>На сайт</span>
  </a>

  <div class="tour-canvas">
    <p class="tour-loading" data-tour-loading role="status">Панорама загружается</p>
    <iframe
      id="erzia-panorama"
      data-tour-frame
      src={frameSrc}
      title={frameTitle}
      allowfullscreen
      tabindex="-1"
    ></iframe>
  </div>

  <div class="tour-intro" data-tour-intro>
    <div class="tour-intro__copy">
      <p class="tour-kicker">{kicker}</p>
      <h1 id="tour-title">{heading[0]}<br />{heading[1]}</h1>
      <p class="tour-summary">{summary}</p>
      <button class="tour-enter" type="button" data-tour-enter>
        <span>Войти в выставку</span>
        <span aria-hidden="true">→</span>
      </button>
    </div>
    <p class="tour-hint" aria-hidden="true">Поворачивайте панораму мышью или касанием</p>
  </div>

  <noscript><style is:global>.tour-intro,.tour-loading{display:none!important}</style></noscript>
</section>

<script>
  import { initTour } from "./tour-controller";

  const shell = document.querySelector<HTMLElement>("[data-tour-shell]");
  if (shell) {
    const cleanup = initTour(shell, { backHref: shell.dataset.backHref || "/" });
    document.addEventListener("astro:before-swap", cleanup, { once: true });
  }
</script>
