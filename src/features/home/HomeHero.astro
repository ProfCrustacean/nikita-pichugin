---
import type { HomePageModel } from "./home-model";

interface Props {
  hero: HomePageModel["hero"];
}

const { hero } = Astro.props;
---

<section class="home-hero" aria-labelledby="home-title">
  <img
    class="home-hero__image"
    src={hero.image}
    alt=""
    width={hero.width}
    height={hero.height}
    fetchpriority="high"
  />
  <div class="home-hero__shade" aria-hidden="true"></div>
  <div class="home-hero__content">
    <h1 id="home-title">{hero.firstName} <em>{hero.lastName}</em></h1>
    <div class="home-hero__bottom">
      <p>{hero.strapline}</p>
      <p>«{hero.workTitle}»</p>
    </div>
  </div>
</section>
