---
import { siteContent } from "@lib/content";
---

<footer class="site-footer">
  <a class="brand-lockup brand-lockup--mark" href="/" aria-label={`${siteContent.brand.name}: на главную`}>
    <img class="brand-mark" src="/content/brand/np-logo.png" width="300" height="300" alt="" />
  </a>
  <nav class="footer-nav" aria-label="Нижняя навигация">
    {siteContent.navigation.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
  <small>© {new Date().getFullYear()}</small>
</footer>
