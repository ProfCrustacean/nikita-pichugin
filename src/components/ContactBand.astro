---
import { siteContent } from "@lib/content";

const socialLinks = siteContent.contact.social.map((item) => {
  const url = new URL(item.href);
  return {
    ...item,
    text: `${url.hostname.replace(/^www\./, "")}/${url.pathname.replace(/^\//, "")}`
  };
});
---

<section class="section section--final contact-stage" id="contact" aria-labelledby="contact-title">
  <div class="section__inner contact-band">
    <div class="contact-band__copy">
      <span class="rule-label">Связь</span>
      <h2 id="contact-title">Контакты</h2>
      <span class="cyan-rule"></span>
      <p class="page-lead">{siteContent.contact.description}</p>
      <a class="outline-button" href={siteContent.contact.emailHref}>
        <span>Написать</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
    <div class="contact-list">
      <a href={siteContent.contact.phoneHref}><span>Телефон</span>{siteContent.contact.phone}</a>
      <a href={siteContent.contact.emailHref}><span>E-mail</span>{siteContent.contact.email}</a>
      {socialLinks.map((item) => <a href={item.href} target="_blank" rel="noreferrer"><span>{item.label}</span>{item.text}</a>)}
    </div>
  </div>
</section>
