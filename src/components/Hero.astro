---
import HeroStage from "@components/HeroStage";
import { getArtworkBySlug, getArtworkImage, siteContent } from "@lib/content";

const highlights = siteContent.highlights
  .map((slug) => getArtworkBySlug(slug))
  .filter(Boolean)
  .map((artwork) => ({
    slug: artwork!.slug,
    title: artwork!.title,
    year: artwork!.year,
    image: getArtworkImage(artwork!)?.localPath
  }));
const stageImages = [
  ...siteContent.homeGallery.images.slice(0, 5).map((item) => item.localPath),
  ...highlights.map((item) => item.image).filter(Boolean)
].slice(0, 5) as string[];
const portrait = siteContent.portrait;
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__canvas" aria-hidden="true">
    <HeroStage client:media="(prefers-reduced-motion: no-preference)" images={stageImages} />
  </div>
  <figure class="hero__portrait">
    <div class="hero__portrait-frame">
      <img src={portrait.localPath} width={portrait.width} height={portrait.height} alt={portrait.alt} loading="eager" />
      <span class="hero__portrait-mark" aria-hidden="true">мастерская / 2024</span>
    </div>
  </figure>
  <div class="hero__identity">
    <h1 id="hero-title" class="hero__title" aria-label={siteContent.brand.name}>
      <span>Никита</span>
      <span>Пичугин</span>
    </h1>
    <p class="hero__subtitle">{siteContent.brand.description}</p>
    <div class="hero__intro">
      <p>
        <span>{siteContent.intro.text}</span>
        <span class="hero__intro-translation">{siteContent.intro.englishText}</span>
      </p>
      <a class="underlined-link" href={siteContent.intro.virtualTourUrl} target="_blank" rel="noreferrer">Виртуальная экскурсия</a>
    </div>
  </div>
  <a class="hero__scroll" href="#works" aria-label="Листать к работам">
    <span class="scroll-icon" aria-hidden="true"></span>
    <span>Листайте вниз</span>
  </a>
</section>
