---
import { museumSiteContent } from "@lib/museum";
import { siteNavigation } from "@lib/navigation";

const path = Astro.url.pathname;
const isActive = (href: string) => href === "/"
  ? path === "/"
  : path === href || path.startsWith(href);
---

<header class="sunday-header" data-site-header>
  <a class="sunday-mark" href="/" aria-label="Никита Пичугин — на главную">
    <img src="/favicon.png" width="42" height="42" alt="" />
  </a>

  <nav class="sunday-nav" id="sunday-navigation" aria-label="Основная навигация" data-site-navigation>
    {siteNavigation.map((item) => (
      <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>{item.label}</a>
    ))}
  </nav>

  <a class="sunday-header__contact" href={`mailto:${museumSiteContent.contact.email}`}>Написать</a>
  <button
    class="sunday-menu-button"
    type="button"
    aria-controls="sunday-navigation"
    aria-expanded="false"
    data-site-menu-button
  >
    <span></span><span></span>
    <span class="sr-only">Открыть меню</span>
  </button>
</header>

<script>
  import { initHeader } from "../features/shell/header-controller";

  const header = document.querySelector<HTMLElement>("[data-site-header]");
  const inertTargets = Array.from(document.querySelectorAll<HTMLElement>("main, .sunday-footer"));
  if (header) initHeader(header, { inertTargets });
</script>
