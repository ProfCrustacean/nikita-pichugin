---
import { museumSiteContent } from "@lib/museum";

interface Props {
  entry: string;
  headingId?: string;
}

const {
  entry,
  headingId = "exhibition-invitation-title"
} = Astro.props;
---

<section class="exhibition-invitation" aria-labelledby={headingId}>
  <a
    class="exhibition-invitation__link"
    href={museumSiteContent.exhibitionTourPath}
    data-exhibition-entry={entry}
  >
    <div class="exhibition-invitation__media" data-sunday-reveal>
      <img
        src="/site/exhibition-hall.webp"
        alt="Картины Никиты Пичугина в зале Музея Эрьзи"
        width="2000"
        height="2000"
        loading="lazy"
      />
    </div>
    <div class="exhibition-invitation__copy" data-sunday-reveal>
      <p class="sunday-kicker">Выставка · Музей Эрьзи</p>
      <h2 id={headingId}>Оказаться<br />среди работ.</h2>
      <p>Пять панорамных точек выставки Никиты Пичугина в Саранске.</p>
      <span class="exhibition-invitation__action">
        <span>Войти в выставку</span>
        <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</section>

<style>
  .exhibition-invitation {
    color: var(--white);
    background: #25241f;
  }

  .exhibition-invitation__link {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(360px, 0.75fr);
    min-height: 86svh;
    overflow: hidden;
  }

  .exhibition-invitation__media {
    min-height: 86svh;
    overflow: hidden;
  }

  .exhibition-invitation__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 43%;
    transform: scale(1.025);
    transition: filter 500ms ease, transform 1100ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .exhibition-invitation__copy {
    display: grid;
    align-content: center;
    gap: clamp(24px, 3.4vw, 48px);
    padding: clamp(70px, 8vw, 138px) var(--gutter);
  }

  .exhibition-invitation__copy h2,
  .exhibition-invitation__copy > p {
    margin: 0;
  }

  .exhibition-invitation__copy h2 {
    font: 400 clamp(58px, 7.2vw, 116px)/0.88 var(--serif);
    letter-spacing: -0.07em;
  }

  .exhibition-invitation__copy > p:not(.sunday-kicker) {
    max-width: 340px;
    color: rgba(255, 250, 240, 0.68);
    font: 400 14px/1.65 var(--sans);
  }

  .exhibition-invitation__action {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    width: 100%;
    max-width: 340px;
    padding: 15px 0;
    border-top: 1px solid rgba(255, 250, 240, 0.28);
    border-bottom: 1px solid rgba(255, 250, 240, 0.28);
    font: 600 9px/1 var(--sans);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .exhibition-invitation__action > span:last-child {
    font-size: 15px;
    transition: transform 220ms ease;
  }

  .exhibition-invitation__copy[data-sunday-reveal] {
    transition-delay: 100ms;
  }

  .exhibition-invitation__link:hover .exhibition-invitation__media img,
  .exhibition-invitation__link:focus-visible .exhibition-invitation__media img {
    filter: saturate(1.04);
    transform: scale(1.055);
  }

  .exhibition-invitation__link:hover .exhibition-invitation__action > span:last-child,
  .exhibition-invitation__link:focus-visible .exhibition-invitation__action > span:last-child {
    transform: translateX(5px);
  }

  @media (max-width: 760px) {
    .exhibition-invitation__link {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .exhibition-invitation__media {
      min-height: 58svh;
    }

    .exhibition-invitation__media img {
      object-position: 50% 42%;
    }

    .exhibition-invitation__copy {
      gap: 28px;
      padding: 76px 20px 88px;
    }

    .exhibition-invitation__copy h2 {
      font-size: clamp(58px, 18vw, 88px);
    }

    .exhibition-invitation__action {
      max-width: none;
    }
  }
</style>
