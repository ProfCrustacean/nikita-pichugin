---
import WorkDetailView from "../../features/work-detail/WorkDetailView.astro";
import { buildWorkDetailPageModel } from "../../features/work-detail/work-detail-model";
import SundayLayout from "@layouts/SundayLayout.astro";
import { museumWorks, type MuseumWork } from "@lib/museum";

export function getStaticPaths() {
  return museumWorks.map((work) => ({
    params: { catalog: work.publicSlug },
    props: { work }
  }));
}

interface Props {
  work: MuseumWork;
}

const { work } = Astro.props;
const origin = Astro.site ?? Astro.url.origin;
const model = buildWorkDetailPageModel(work, {
  pageUrl: new URL(Astro.url.pathname, origin),
  assetOrigin: origin,
  works: museumWorks
});
---

<SundayLayout
  title={model.pageTitle}
  description={model.seoDescription}
  image={model.primaryMedia.src}
  imageAlt={model.publicTitle}
  ogType="article"
  bodyClass="work-detail-page"
  jsonLd={model.jsonLd}
>
  <WorkDetailView model={model} />
</SundayLayout>
