---
import SundayLayout from "@layouts/SundayLayout.astro";
import MuseumWorkCard from "@components/MuseumWorkCard.astro";
import {
  getAdjacentWork,
  getPreviewPath,
  getPrimaryAsset,
  getPublicTitle,
  getPublicDescription,
  getKnownWorkDate,
  getWorkAssets,
  getWorkDate,
  getWorkDateForSentence,
  getWorkHref,
  hasCataloguerDescriptiveTitle,
  getWorkTypeLabel,
  museumWorks,
  type MuseumWork
} from "@lib/museum";

export function getStaticPaths() {
  return museumWorks.map((work) => ({
    params: { catalog: work.publicSlug },
    props: { work }
  }));
}

interface Props {
  work: MuseumWork;
}

const { work } = Astro.props;
const publicTitle = getPublicTitle(work);
const assets = getWorkAssets(work);
const primaryAsset = getPrimaryAsset(work);
const secondaryReproductions = assets.filter((asset) =>
  asset.assetId !== primaryAsset.assetId && asset.visualClass === "artwork_reproduction"
);
const associatedAssets = assets.filter((asset) =>
  asset.assetId !== primaryAsset.assetId && asset.visualClass !== "artwork_reproduction"
);
const description = getPublicDescription(work);
const titleIsEditorial = hasCataloguerDescriptiveTitle(work);
const { previous, next } = getAdjacentWork(work);
const firstGenre = work.subjects.genre.find((genre) => !["painting", "photography"].includes(genre));
const relatedWorks = museumWorks
  .filter((candidate) =>
    candidate.workId !== work.workId &&
    candidate.recordType === work.recordType &&
    (firstGenre ? candidate.subjects.genre.includes(firstGenre) : candidate.objectWorkType === work.objectWorkType)
  )
  .slice(0, 3);

const knownDate = getKnownWorkDate(work);
const dimensions = work.physicalDescription.dimensions.display
  ? `${work.physicalDescription.dimensions.display}${work.physicalDescription.dimensions.unit === "cm" ? " см" : ""}`
  : null;
const metadata = [
  { label: work.recordType === "photographic_work" ? "Дата съёмки" : "Год", value: knownDate, show: Boolean(knownDate) },
  { label: "Материал и техника", value: work.physicalDescription.materialsTechniquesDisplay, show: work.physicalDescription.status === "known" },
  {
    label: "Размер",
    value: dimensions,
    show: work.physicalDescription.dimensions.status === "known"
  }
].filter((item) => item.show && item.value);
const sentenceDate = getWorkDateForSentence(work);
const seoDescription = work.recordType === "photographic_work"
  ? `Фотокомпозиция Никиты Пичугина.${sentenceDate ? ` Дата съёмки: ${sentenceDate}.` : ""}`
  : [
      `«${publicTitle}». Никита Пичугин${work.creation.displayDate ? `, ${work.creation.displayDate}` : ""}.`,
      work.physicalDescription.status === "known" && work.physicalDescription.materialsTechniquesDisplay
        ? `${work.physicalDescription.materialsTechniquesDisplay}.`
        : null,
      work.physicalDescription.dimensions.status === "known" && dimensions ? `${dimensions}.` : null
    ].filter(Boolean).join(" ");
const pageTitle = work.recordType === "photographic_work" && knownDate
  ? `${publicTitle}, ${knownDate}`
  : publicTitle;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "VisualArtwork",
  name: publicTitle,
  url: new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href,
  image: new URL(getPreviewPath(primaryAsset), Astro.site ?? Astro.url.origin).href,
  creator: { "@type": "Person", name: "Никита Пичугин" },
  artform: getWorkTypeLabel(work),
  inLanguage: "ru",
  ...(work.creation.displayDate ? { dateCreated: work.creation.displayDate } : {}),
  ...(work.recordType === "photographic_work" && work.capture.status === "known" && work.capture.displayDate
    ? { dateCreated: work.capture.displayDate.slice(0, 10) }
    : {}),
  ...(work.physicalDescription.status === "known" && work.physicalDescription.materialsTechniquesDisplay
    ? { artMedium: work.physicalDescription.materialsTechniquesDisplay }
    : {}),
  description: seoDescription
};
---

<SundayLayout
  title={pageTitle}
  description={seoDescription}
  image={getPreviewPath(primaryAsset)}
  imageAlt={publicTitle}
  ogType="article"
  bodyClass="work-detail-page"
  jsonLd={jsonLd}
>
  <article class="work-detail">
    <header class:list={["work-detail__header", { "work-detail__header--photographic": work.recordType === "photographic_work" }]}>
      <a class="sunday-link" href={work.recordType === "artwork" ? "/works/" : "/studio/#photocompositions"}>{work.recordType === "artwork" ? "Назад к собранию" : "Назад к фотокомпозициям"}</a>
      <p class="sunday-kicker">{getWorkTypeLabel(work)}</p>
      <h1>{publicTitle}</h1>
      {titleIsEditorial && work.recordType === "artwork" && <p class="work-detail__editorial">Название дано редакцией; авторское название не указано.</p>}
    </header>

    <figure class="work-detail__primary" data-work-asset-id={primaryAsset.assetId}>
      <img
        src={getPreviewPath(primaryAsset)}
        alt={publicTitle}
        width={primaryAsset.previewWidthPx}
        height={primaryAsset.previewHeightPx}
        fetchpriority="high"
      />
      <figcaption>{getWorkDate(work)}</figcaption>
    </figure>

    {(description || metadata.length > 0) && (
      <section class:list={["work-detail__record", { "work-detail__record--description-only": metadata.length === 0 }]} aria-labelledby="record-heading">
        <div>
          <h2 id="record-heading">Сведения о работе</h2>
          {description && <p class="work-detail__description">{description}</p>}
        </div>
        {metadata.length > 0 && (
          <dl>
            {metadata.map((item) => (
              <div>
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
        )}
      </section>
    )}

    {secondaryReproductions.length > 0 && (
      <section class="work-media" aria-labelledby="views-heading">
        <header>
          <p class="sunday-kicker">Другие виды</p>
          <h2 id="views-heading">Та же работа,<br />другой кадр.</h2>
        </header>
        <div class="work-media__grid">
          {secondaryReproductions.map((asset) => (
            <figure data-work-asset-id={asset.assetId}>
              <img src={getPreviewPath(asset)} alt={`Другое изображение работы «${publicTitle}»`} width={asset.previewWidthPx} height={asset.previewHeightPx} loading="lazy" />
              <figcaption>Другое изображение работы</figcaption>
            </figure>
          ))}
        </div>
      </section>
    )}

    {associatedAssets.length > 0 && (
      <section class="work-media work-media--warm" aria-labelledby="materials-heading">
        <header>
          <p class="sunday-kicker">Материалы к работе</p>
          <h2 id="materials-heading">Связанные<br />изображения.</h2>
          <p class="work-media__context">Изображения были опубликованы вместе с работой; их роль не установлена.</p>
        </header>
        <div class="work-media__grid">
          {associatedAssets.map((asset) => (
            <figure data-work-asset-id={asset.assetId}>
              <img src={getPreviewPath(asset)} alt={`Материал, опубликованный вместе с работой «${publicTitle}»`} width={asset.previewWidthPx} height={asset.previewHeightPx} loading="lazy" />
              <figcaption>Связанное изображение</figcaption>
            </figure>
          ))}
        </div>
      </section>
    )}

    {relatedWorks.length > 0 && (
      <section class="work-related" aria-labelledby="related-heading">
        <header>
          <p class="sunday-kicker">Рядом в собрании</p>
          <h2 id="related-heading">Продолжить смотреть</h2>
        </header>
        <div>
          {relatedWorks.map((related) => <MuseumWorkCard work={related} compact />)}
        </div>
      </section>
    )}

    <nav class="work-detail__next" aria-label="Соседние работы">
      {previous ? <a href={getWorkHref(previous)}><span>Предыдущая</span><strong>{getPublicTitle(previous)}</strong></a> : <span></span>}
      {next ? <a href={getWorkHref(next)}><span>Следующая</span><strong>{getPublicTitle(next)}</strong></a> : <span></span>}
    </nav>
  </article>
</SundayLayout>

<style>
  .work-detail__header {
    display: grid;
    grid-template-columns: 0.55fr 1.45fr;
    gap: 34px 7vw;
    align-content: end;
    min-height: 72svh;
    padding: 130px var(--gutter) 72px;
  }

  .work-detail__header .sunday-link {
    align-self: start;
  }

  .work-detail__header .sunday-kicker,
  .work-detail__header h1,
  .work-detail__editorial {
    grid-column: 2;
  }

  .work-detail__header h1 {
    max-width: 1160px;
    margin: 0;
    font: 400 clamp(68px, 11vw, 174px)/0.82 var(--serif);
    letter-spacing: -0.075em;
    text-wrap: balance;
  }

  .work-detail__header--photographic h1 {
    font-size: clamp(52px, 8.2vw, 126px);
  }

  .work-detail__editorial {
    max-width: 360px;
    margin: 0;
    color: var(--ink-soft);
    font: 400 12px/1.5 var(--sans);
  }

  .work-detail__primary {
    display: grid;
    place-items: center;
    min-height: 100svh;
    margin: 0;
    padding: clamp(70px, 9vw, 130px) var(--gutter) 42px;
    background: #d9d6cc;
  }

  .work-detail__primary img {
    width: auto;
    max-width: min(100%, 1500px);
    max-height: 82svh;
    object-fit: contain;
    box-shadow: 0 24px 80px rgba(34, 34, 29, 0.16);
  }

  .work-detail__primary figcaption {
    justify-self: end;
    padding-top: 22px;
    color: var(--ink-soft);
    font: 600 8px/1 var(--sans);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .work-detail__record,
  .work-media > header,
  .work-related > header {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 50px 8vw;
  }

  .work-detail__record {
    grid-template-columns: 0.8fr 1.2fr;
    padding: clamp(100px, 13vw, 190px) var(--gutter);
  }

  .work-detail__record > div:first-child {
    display: grid;
    align-content: start;
    gap: 28px;
  }

  .work-detail__record--description-only > div:first-child {
    grid-column: 2;
  }

  .work-detail__record h2,
  .work-media h2,
  .work-related h2 {
    margin: 0;
    font: 400 clamp(48px, 7vw, 108px)/0.92 var(--serif);
    letter-spacing: -0.065em;
  }

  .work-detail__description {
    max-width: 480px;
    margin: 0;
    font: 400 16px/1.65 var(--sans);
  }

  .work-detail__record dl {
    margin: 0;
    border-top: 1px solid var(--line);
  }

  .work-detail__record dl > div {
    display: grid;
    grid-template-columns: minmax(150px, 0.5fr) 1fr;
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
  }

  .work-detail__record dt {
    color: var(--ink-soft);
    font: 600 8px/1.4 var(--sans);
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .work-detail__record dd {
    margin: 0;
    font: 400 clamp(18px, 1.7vw, 26px)/1.2 var(--serif);
  }

  .work-media__context {
    grid-column: 2;
    max-width: 430px;
    margin: 0;
    color: var(--ink-soft);
    font: 400 11px/1.55 var(--sans);
  }

  .work-media {
    padding: clamp(90px, 12vw, 180px) var(--gutter);
    background: #e8e4d9;
  }

  .work-media--warm {
    background: var(--paper-deep);
  }

  .work-media > header,
  .work-related > header {
    margin-bottom: clamp(70px, 9vw, 130px);
  }

  .work-media h2,
  .work-related h2 {
    grid-column: 2;
  }

  .work-media__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(50px, 8vw, 120px) clamp(26px, 5vw, 80px);
    align-items: start;
  }

  .work-media figure {
    margin: 0;
  }

  .work-media figure:nth-child(even) {
    margin-top: 10vw;
  }

  .work-media img {
    width: 100%;
    max-height: 84svh;
    object-fit: contain;
  }

  .work-media figcaption {
    padding-top: 13px;
    color: var(--ink-soft);
    font: 600 8px/1 var(--sans);
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .work-related {
    padding: clamp(100px, 13vw, 190px) var(--gutter);
  }

  .work-related > div {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(22px, 4vw, 64px);
  }

  .work-detail__next {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid var(--line);
  }

  .work-detail__next > a {
    display: grid;
    gap: 14px;
    min-height: 230px;
    padding: 50px var(--gutter);
    align-content: center;
    transition: background 220ms ease;
  }

  .work-detail__next > a:last-child {
    text-align: right;
    border-left: 1px solid var(--line);
  }

  .work-detail__next > a:hover {
    background: var(--paper-deep);
  }

  .work-detail__next span {
    color: var(--ink-soft);
    font: 600 8px/1 var(--sans);
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .work-detail__next strong {
    font: 400 clamp(26px, 3vw, 48px)/1 var(--serif);
    letter-spacing: -0.045em;
  }

  @media (max-width: 760px) {
    .work-detail__header,
    .work-detail__record,
    .work-media > header,
    .work-related > header {
      grid-template-columns: 1fr;
    }

    .work-detail__header {
      min-height: 66svh;
      padding: 110px 20px 60px;
    }

    .work-detail__header .sunday-kicker,
    .work-detail__header h1,
    .work-detail__editorial,
    .work-media h2,
    .work-media__context,
    .work-related h2 {
      grid-column: 1;
    }

    .work-detail__header h1 {
      min-width: 0;
      font-size: clamp(48px, 12.6vw, 88px);
    }

    .work-detail__primary {
      min-height: auto;
      padding: 70px 20px 28px;
    }

    .work-detail__record,
    .work-media,
    .work-related {
      padding-inline: 20px;
    }

    .work-detail__record--description-only > div:first-child {
      grid-column: 1;
    }

    .work-detail__record dl > div {
      grid-template-columns: 0.7fr 1.3fr;
    }

    .work-media__grid,
    .work-related > div,
    .work-detail__next {
      grid-template-columns: 1fr;
    }

    .work-media figure:nth-child(even) {
      margin-top: 0;
    }

    .work-detail__next > a:last-child {
      border-top: 1px solid var(--line);
      border-left: 0;
    }
  }
</style>
