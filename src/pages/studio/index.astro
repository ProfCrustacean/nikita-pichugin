---
import StudioPage from "../../features/studio/StudioPage.astro";
import { buildStudioPageModel } from "../../features/studio/studio-model";
import SundayLayout from "@layouts/SundayLayout.astro";

const model = buildStudioPageModel();
const studioJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: "Мастерская Никиты Пичугина",
  url: new URL("/studio/", Astro.site ?? Astro.url.origin).href,
  mainEntity: {
    "@type": "Person",
    name: "Никита Пичугин",
    jobTitle: "Художник",
    image: new URL(model.portrait.src, Astro.site ?? Astro.url.origin).href
  }
};
---

<SundayLayout
  title="Мастерская"
  description="Мастерская художника Никиты Пичугина: портрет, рабочее пространство, материалы и фотокомпозиции."
  image={model.portrait.src}
  imageAlt={model.portrait.alt}
  bodyClass="studio-page"
  jsonLd={studioJsonLd}
>
  <StudioPage model={model} />
</SundayLayout>
