---
import SundayLayout from "@layouts/SundayLayout.astro";
import ObservationWall from "@components/ObservationWall.astro";
import {
  getAssetById,
  getPreviewPath,
  museumAssets,
  museumSiteContent,
  observationWorks
} from "@lib/museum";

const portrait = getAssetById(museumSiteContent.portraitAssetId)!;
const processAssets = museumAssets
  .filter((asset) => asset.visualClass === "studio_or_process_photo");
const processAltByAssetId: Record<string, string> = {
  asset_08ac8803d649faaf: "Стеклянные банки, бутылки и воронки на рабочем столе",
  asset_174f128d44438c22: "Тюбики краски, кисти и палитры на рабочем столе",
  asset_1b3d75f817a204bf: "Мастерская с мольбертом, кистями и палитрой у окна",
  asset_310b6ce3e51ffd6d: "Мастихины и тюбик краски на палитре",
  asset_6d54118d52c52bb2: "Использованные тюбики масляной краски",
  asset_7d16ead8bfee2494: "Часы и стеклянные бутылки на подоконнике",
  asset_8602da5950efa51b: "Рабочий стол и мольберт у окна мастерской",
  asset_966adab31ca2accb: "Деревянный мольберт с небольшой работой и палитрой",
  asset_cad10fc3fab6fa13: "Тюбики краски и мастихины на рабочем столе",
  asset_cfb5cc509c885bf8: "Кисти в банках у окна",
  asset_e76222b77938079e: "Кисти, бутылки и лейка на подоконнике мастерской"
};
const studioJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: "Мастерская Никиты Пичугина",
  url: new URL("/studio/", Astro.site ?? Astro.url.origin).href,
  mainEntity: {
    "@type": "Person",
    name: "Никита Пичугин",
    jobTitle: "Художник",
    image: new URL(getPreviewPath(portrait), Astro.site ?? Astro.url.origin).href
  }
};
---

<SundayLayout
  title="Мастерская"
  description="Мастерская художника Никиты Пичугина: портрет, рабочее пространство, материалы и фотокомпозиции."
  image={getPreviewPath(portrait)}
  imageAlt="Портрет Никиты Пичугина"
  bodyClass="studio-page"
  jsonLd={studioJsonLd}
>
  <header class="studio-hero">
    <div class="studio-hero__copy">
      <p class="sunday-kicker">Художник</p>
      <h1>Мастерская</h1>
      <p>Портрет Никиты Пичугина и предметы его рабочего пространства.</p>
    </div>
    <div class="studio-hero__portrait">
      <img
        src={getPreviewPath(portrait)}
        alt="Портрет Никиты Пичугина"
        width={portrait.previewWidthPx}
        height={portrait.previewHeightPx}
        fetchpriority="high"
      />
    </div>
  </header>

  <section class="studio-statement" data-sunday-reveal>
    <p class="sunday-kicker">В мастерской</p>
    <div>
      <h2>Краски, кисти,<br />инструменты.</h2>
      <p>Здесь собраны кадры инструментов, красок и предметов из рабочего пространства художника.</p>
    </div>
  </section>

  <section class="studio-process" aria-label="Материалы мастерской">
    {processAssets.map((asset, index) => (
      <figure class={`studio-process__item studio-process__item--${(index % 4) + 1}`} data-sunday-reveal>
        <img
          src={getPreviewPath(asset)}
          alt={processAltByAssetId[asset.assetId] ?? "Рабочее пространство художника"}
          width={asset.previewWidthPx}
          height={asset.previewHeightPx}
          loading="lazy"
        />
      </figure>
    ))}
  </section>

  <section class="studio-tour" data-sunday-reveal aria-labelledby="exhibition-tour-title">
    <p class="sunday-kicker">Выставка в Музее Эрьзи</p>
    <div>
      <h2 id="exhibition-tour-title">Пройти<br />по выставке.</h2>
      <p>Виртуальный проход по выставке Никиты Пичугина в Мордовском республиканском музее изобразительных искусств имени С. Д. Эрьзи.</p>
      <a
        class="sunday-link"
        href={museumSiteContent.exhibitionTourPath}
        aria-label="Войти в виртуальный тур по выставке в Музее Эрьзи"
      >Войти в выставку</a>
    </div>
  </section>

  <section class="studio-observations" id="photocompositions" aria-labelledby="observations-title">
    <header data-sunday-reveal>
      <p class="sunday-kicker">Фотокомпозиции · {observationWorks.length}</p>
      <div>
        <h2 id="observations-title">Самое интересное возникает внезапно.</h2>
        <blockquote>
          <p>С детства меня завораживает игра солнечного света. За сюжетом бесполезно охотиться специально — он встречается в обычном дне.</p>
          <cite>Никита Пичугин</cite>
        </blockquote>
      </div>
    </header>
    <ObservationWall works={observationWorks} />
  </section>
</SundayLayout>

<style>
  :global(.studio-page .sunday-header:not(.is-scrolled)) {
    background: linear-gradient(90deg, rgba(226, 220, 203, 0.94) 70%, rgba(226, 220, 203, 0.72));
  }

  .studio-hero {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    min-height: 100svh;
    background: var(--paper-deep);
  }

  .studio-hero__copy {
    display: grid;
    align-content: end;
    gap: 32px;
    padding: 130px var(--gutter) 72px;
  }

  .studio-hero h1 {
    margin: 0;
    font: 400 clamp(82px, 13vw, 190px)/0.74 var(--serif);
    letter-spacing: -0.085em;
  }

  .studio-hero__copy > p:last-child {
    max-width: 390px;
    margin: 0;
    font: 400 15px/1.65 var(--sans);
  }

  .studio-hero__portrait {
    min-height: 100svh;
  }

  .studio-hero__portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 42%;
  }

  .studio-statement,
  .studio-tour,
  .studio-observations > header {
    display: grid;
    grid-template-columns: 0.7fr 1.3fr;
    gap: clamp(42px, 8vw, 150px);
    padding: clamp(100px, 13vw, 190px) var(--gutter);
  }

  .studio-statement > div,
  .studio-tour > div,
  .studio-observations > header > div {
    display: grid;
    gap: 34px;
  }

  .studio-statement h2,
  .studio-tour h2,
  .studio-observations h2 {
    max-width: 980px;
    margin: 0;
    font: 400 clamp(50px, 7.4vw, 112px)/0.92 var(--serif);
    letter-spacing: -0.065em;
  }

  .studio-statement div > p,
  .studio-tour div > p,
  .studio-observations blockquote p {
    max-width: 450px;
    margin: 0;
    font: 400 15px/1.65 var(--sans);
  }

  .studio-observations blockquote {
    display: grid;
    gap: 18px;
    margin: 0;
  }

  .studio-observations cite {
    color: var(--ink-soft);
    font: 600 9px/1 var(--sans);
    font-style: normal;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .studio-process {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: clamp(20px, 4vw, 70px);
    padding: 0 var(--gutter) clamp(110px, 14vw, 220px);
  }

  .studio-process figure {
    margin: 0;
  }

  .studio-process__item--1 {
    grid-column: 1 / span 7;
  }

  .studio-process__item--2 {
    grid-column: 9 / span 4;
    margin-top: 12vw !important;
  }

  .studio-process__item--3 {
    grid-column: 2 / span 4;
    margin-top: 5vw !important;
  }

  .studio-process__item--4 {
    grid-column: 7 / span 6;
  }

  .studio-process img {
    width: 100%;
    max-height: 82svh;
    object-fit: cover;
  }

  .studio-tour {
    min-height: 86svh;
    align-content: center;
    color: var(--white);
    background: #6c715e;
  }

  .studio-observations {
    padding-bottom: clamp(120px, 14vw, 220px);
  }

  .studio-observations > :global(.observation-wall) {
    margin-inline: var(--gutter);
  }

  @media (max-width: 760px) {
    .studio-hero,
    .studio-statement,
    .studio-tour,
    .studio-observations > header {
      grid-template-columns: minmax(0, 1fr);
    }

    .studio-hero {
      min-height: auto;
    }

    .studio-hero__copy {
      min-width: 0;
      min-height: 72svh;
      padding: 110px 20px 60px;
    }

    .studio-hero h1 {
      font-size: clamp(60px, 18vw, 84px);
    }

    .studio-hero__portrait {
      min-height: 76svh;
    }

    .studio-statement,
    .studio-tour,
    .studio-observations > header {
      gap: 46px;
      padding-inline: 20px;
    }

    .studio-process {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      padding-inline: 20px;
    }

    .studio-process__item--1,
    .studio-process__item--2,
    .studio-process__item--3,
    .studio-process__item--4 {
      grid-column: auto;
      margin-top: 0 !important;
    }

    .studio-process__item:nth-child(3n + 1) {
      grid-column: 1 / -1;
    }

    .studio-observations > :global(.observation-wall) {
      margin-inline: 20px;
    }
  }
</style>
