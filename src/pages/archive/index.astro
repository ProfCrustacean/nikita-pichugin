---
import SundayLayout from "@layouts/SundayLayout.astro";
import MuseumWorkCard from "@components/MuseumWorkCard.astro";
import { artworkWorks } from "@lib/museum";

const grouped = Map.groupBy(artworkWorks, (work) => work.creation.earliestYear?.toString() ?? "unknown");
const years = Array.from(grouped.keys()).sort((a, b) => {
  if (a === "unknown") return 1;
  if (b === "unknown") return -1;
  return Number(b) - Number(a);
});
const countLabel = (count: number) => {
  if (count % 10 === 1 && count % 100 !== 11) return `${count} работа`;
  if ([2, 3, 4].includes(count % 10) && ![12, 13, 14].includes(count % 100)) return `${count} работы`;
  return `${count} работ`;
};
const archiveJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Архив работ Никиты Пичугина по годам",
  url: new URL("/archive/", Astro.site ?? Astro.url.origin).href,
  mainEntity: { "@type": "ItemList", numberOfItems: artworkWorks.length }
};
---

<SundayLayout
  title="Архив по годам"
  description="Архив работ Никиты Пичугина по годам: живопись и работы на бумаге."
  bodyClass="archive-page"
  jsonLd={archiveJsonLd}
>
  <header class="archive-hero">
    <p class="sunday-kicker">Хронология</p>
    <h1>Архив<br /><em>по годам</em></h1>
    <div>
      <p>Работы расположены по годам; произведения без установленной даты собраны отдельно.</p>
      <a class="sunday-link" href="#timeline">Смотреть хронологию</a>
    </div>
  </header>

  <nav class="archive-years" aria-label="Годы архива">
    {years.map((year) => <a href={`#year-${year}`}>{year === "unknown" ? "Без даты" : year}</a>)}
  </nav>

  <div class="archive-timeline" id="timeline">
    {years.map((year) => {
      const works = grouped.get(year) ?? [];
      return (
        <section class="archive-year" id={`year-${year}`}>
          <header>
            <h2>{year === "unknown" ? "Без даты" : year}</h2>
            <p>{countLabel(works.length)}</p>
          </header>
          <div class="archive-year__grid">
            {works.map((work) => <MuseumWorkCard work={work} compact />)}
          </div>
        </section>
      );
    })}
  </div>
</SundayLayout>

<style>
  .archive-hero {
    display: grid;
    grid-template-columns: 0.55fr 1.45fr;
    gap: 40px 7vw;
    align-content: end;
    min-height: 76svh;
    padding: 130px var(--gutter) 70px;
    background: var(--paper);
  }

  .archive-hero h1 {
    grid-column: 2;
    margin: 0;
    font: 400 clamp(86px, 14vw, 210px)/0.72 var(--serif);
    letter-spacing: -0.085em;
  }

  .archive-hero h1 em {
    font-weight: 400;
  }

  .archive-hero > div {
    grid-column: 2;
    display: grid;
    gap: 32px;
  }

  .archive-hero > div p {
    max-width: 420px;
    margin: 0;
    font: 400 15px/1.65 var(--sans);
  }

  .archive-years {
    position: sticky;
    top: 64px;
    z-index: 10;
    display: flex;
    gap: 24px;
    padding: 17px var(--gutter);
    overflow-x: auto;
    color: var(--white);
    background: rgba(36, 35, 30, 0.94);
    scrollbar-width: none;
    backdrop-filter: blur(14px);
  }

  .archive-years a {
    flex: 0 0 auto;
    font: 600 9px/1 var(--sans);
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .archive-timeline {
    padding: 60px var(--gutter) clamp(120px, 14vw, 220px);
  }

  .archive-year {
    display: grid;
    grid-template-columns: minmax(150px, 0.35fr) 1.65fr;
    gap: clamp(40px, 7vw, 120px);
    padding: clamp(70px, 9vw, 140px) 0;
    border-bottom: 1px solid var(--line);
    scroll-margin-top: 112px;
  }

  .archive-year > header {
    position: sticky;
    top: 120px;
    align-self: start;
    display: flex;
    justify-content: space-between;
    gap: 18px;
  }

  .archive-year h2,
  .archive-year header p {
    margin: 0;
  }

  .archive-year h2 {
    font: 400 clamp(34px, 4.5vw, 70px)/1 var(--serif);
    letter-spacing: -0.055em;
  }

  .archive-year header p {
    color: var(--ink-soft);
    font: 600 10px/1 var(--sans);
  }

  .archive-year__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .archive-year__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .archive-hero {
      grid-template-columns: 1fr;
      min-height: 70svh;
      padding: 110px 20px 58px;
    }

    .archive-hero h1,
    .archive-hero > div {
      grid-column: 1;
    }

    .archive-hero h1 {
      font-size: clamp(82px, 27vw, 124px);
    }

    .archive-years {
      padding-inline: 20px;
    }

    .archive-timeline {
      padding-inline: 20px;
    }

    .archive-year {
      grid-template-columns: 1fr;
      gap: 42px;
    }

    .archive-year > header {
      position: static;
    }

    .archive-year__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 15px;
    }
  }
</style>
