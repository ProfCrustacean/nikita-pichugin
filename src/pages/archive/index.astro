---
import SundayLayout from "@layouts/SundayLayout.astro";
import MuseumWorkCard from "@components/MuseumWorkCard.astro";
import { artworkWorks } from "@lib/museum";
import { formatWorksCountRu } from "@lib/format";
import "../../features/archive/archive.css";

const grouped = Map.groupBy(artworkWorks, (work) => work.creation.earliestYear?.toString() ?? "unknown");
const years = Array.from(grouped.keys()).sort((a, b) => {
  if (a === "unknown") return 1;
  if (b === "unknown") return -1;
  return Number(b) - Number(a);
});
const archiveJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Архив работ Никиты Пичугина по годам",
  url: new URL("/archive/", Astro.site ?? Astro.url.origin).href,
  mainEntity: { "@type": "ItemList", numberOfItems: artworkWorks.length }
};
---

<SundayLayout
  title="Архив по годам"
  description="Архив работ Никиты Пичугина по годам: живопись и работы на бумаге."
  bodyClass="archive-page"
  jsonLd={archiveJsonLd}
>
  <header class="archive-hero">
    <p class="sunday-kicker">Хронология</p>
    <h1>Архив<br /><em>по годам</em></h1>
    <div>
      <p>Работы расположены по годам; произведения без установленной даты собраны отдельно.</p>
      <a class="sunday-link" href="#timeline">Смотреть хронологию</a>
    </div>
  </header>

  <nav class="archive-years" aria-label="Годы архива">
    {years.map((year) => <a href={`#year-${year}`}>{year === "unknown" ? "Без даты" : year}</a>)}
  </nav>

  <div class="archive-timeline" id="timeline">
    {years.map((year) => {
      const works = grouped.get(year) ?? [];
      return (
        <section class="archive-year" id={`year-${year}`}>
          <header>
            <h2>{year === "unknown" ? "Без даты" : year}</h2>
            <p>{formatWorksCountRu(works.length)}</p>
          </header>
          <div class="archive-year__grid">
            {works.map((work) => <MuseumWorkCard work={work} compact />)}
          </div>
        </section>
      );
    })}
  </div>
</SundayLayout>
