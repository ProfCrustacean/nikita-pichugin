---
import SundayLayout from "@layouts/SundayLayout.astro";
import { getPrimaryAsset, getWorkById, museumSiteContent } from "@lib/museum";

const landscape = getWorkById("work_550dd44ad5709fe5")!;
const landscapeAsset = getPrimaryAsset(landscape);
const phoneHref = `tel:${museumSiteContent.contact.phoneHref}`;
const contactJsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Контакты Никиты Пичугина",
  url: new URL("/contact/", Astro.site ?? Astro.url.origin).href,
  about: { "@type": "Person", name: "Никита Пичугин", jobTitle: "Художник" }
};
---

<SundayLayout
  title="Контакты"
  description="Контакты Никиты Пичугина: выставки, приобретение работ и сотрудничество."
  image="/site/contact-hero.webp"
  imageAlt={landscape.displayTitle.ru}
  headerTone="light"
  bodyClass="contact-page"
  jsonLd={contactJsonLd}
>
  <header class="contact-hero">
    <img src="/site/contact-hero.webp" alt="" width={landscapeAsset.previewWidthPx} height={landscapeAsset.previewHeightPx} fetchpriority="high" />
    <div aria-hidden="true"></div>
    <h1>Контакты</h1>
    <p>По вопросам выставок, приобретения работ и сотрудничества.</p>
  </header>

  <section class="contact-main">
    <h2 class="sunday-kicker">Почта и телефон</h2>
    <div class="contact-main__links">
      <a href={`mailto:${museumSiteContent.contact.email}`}>
        <span>Почта</span>
        <strong>{museumSiteContent.contact.email}</strong>
      </a>
      <a href={phoneHref}>
        <span>Телефон</span>
        <strong>{museumSiteContent.contact.phone}</strong>
      </a>
    </div>
  </section>

  <section class="contact-social">
    <h2 class="sunday-kicker">Социальные сети</h2>
    <div>
      <a href={museumSiteContent.contact.telegram} rel="me"><span>Telegram</span><b aria-hidden="true">↗</b></a>
      <a href={museumSiteContent.contact.vk} rel="me"><span>VK</span><b aria-hidden="true">↗</b></a>
    </div>
  </section>
</SundayLayout>

<style>
  .contact-hero {
    position: relative;
    display: grid;
    align-content: end;
    min-height: 82svh;
    padding: 130px var(--gutter) 70px;
    overflow: hidden;
    color: var(--white);
    background: #67705c;
    isolation: isolate;
  }

  .contact-hero > img,
  .contact-hero > div {
    position: absolute;
    inset: 0;
  }

  .contact-hero > img {
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 52%;
  }

  .contact-hero > div {
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(24, 29, 21, 0.38), transparent 38%),
      linear-gradient(0deg, rgba(24, 28, 21, 0.66), transparent 60%);
  }

  .contact-hero h1,
  .contact-hero p {
    margin: 0;
  }

  .contact-hero h1 {
    font: 400 clamp(88px, 15vw, 230px)/0.74 var(--serif);
    letter-spacing: -0.085em;
  }

  .contact-hero > p {
    max-width: 380px;
    margin-top: 34px;
    font: 400 14px/1.55 var(--sans);
  }

  .contact-main,
  .contact-social {
    display: grid;
    grid-template-columns: 0.55fr 1.45fr;
    gap: 50px 8vw;
    padding: clamp(100px, 13vw, 190px) var(--gutter);
  }

  .contact-main__links {
    display: grid;
    border-top: 1px solid var(--line);
  }

  .contact-main__links a {
    display: grid;
    grid-template-columns: 0.4fr 1fr;
    gap: 26px;
    align-items: baseline;
    padding: 28px 0;
    border-bottom: 1px solid var(--line);
  }

  .contact-main__links span {
    color: var(--ink-soft);
    font: 600 8px/1 var(--sans);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .contact-main__links strong {
    font: 400 clamp(26px, 4vw, 62px)/1 var(--serif);
    letter-spacing: -0.045em;
  }

  .contact-social {
    padding-top: 0;
  }

  .contact-social > div {
    display: grid;
    border-top: 1px solid var(--line);
  }

  .contact-social a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 0;
    border-bottom: 1px solid var(--line);
    transition: color 220ms ease, padding 260ms ease;
  }

  .contact-social a:hover,
  .contact-social a:focus-visible {
    color: var(--accent);
    padding-left: 12px;
  }

  .contact-social span {
    font: 400 clamp(34px, 5vw, 72px)/1 var(--serif);
    letter-spacing: -0.045em;
  }

  .contact-social b {
    font-size: 20px;
    font-weight: 400;
  }

  @media (max-width: 700px) {
    .contact-hero {
      min-height: 76svh;
      padding: 110px 20px 52px;
    }

    .contact-hero h1 {
      font-size: clamp(68px, 22vw, 112px);
    }

    .contact-main,
    .contact-social {
      grid-template-columns: 1fr;
      padding-inline: 20px;
    }

    .contact-main__links a {
      grid-template-columns: 1fr;
    }

    .contact-main__links strong {
      font-size: clamp(25px, 8vw, 38px);
      overflow-wrap: anywhere;
    }
  }
</style>
