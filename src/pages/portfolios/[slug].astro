---
import BaseLayout from "@layouts/BaseLayout.astro";
import ArtworkDetail from "@components/ArtworkDetail.astro";
import { siteContent } from "@lib/content";

export function getStaticPaths() {
  return siteContent.artworks.map((artwork) => ({
    params: { slug: artwork.slug },
    props: { artwork }
  }));
}

const { artwork } = Astro.props;
---

<BaseLayout title={artwork.title} description={`${artwork.title}. ${[artwork.medium, artwork.dimensions, artwork.year].filter(Boolean).join(". ")}`}>
  <ArtworkDetail artwork={artwork} />
</BaseLayout>
