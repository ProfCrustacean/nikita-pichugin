---
import ExhibitionInvitation from "@components/ExhibitionInvitation.astro";
import LandscapeJourney from "@components/LandscapeJourney.astro";
import SundayLayout from "@layouts/SundayLayout.astro";
import HomeCollection from "../features/home/HomeCollection.astro";
import HomeHero from "../features/home/HomeHero.astro";
import HomeIntro from "../features/home/HomeIntro.astro";
import HomeStudioTeaser from "../features/home/HomeStudioTeaser.astro";
import "../features/home/home.css";
import { buildHomePageModel } from "../features/home/home-model";

const home = buildHomePageModel(Astro.site ?? Astro.url);
---

<SundayLayout
  headerTone="light"
  bodyClass="sunday-home"
  image={home.seo.image}
  imageAlt={home.seo.imageAlt}
  description={home.seo.description}
  jsonLd={home.seo.jsonLd}
>
  <HomeHero hero={home.hero} />
  <HomeIntro intro={home.intro} />
  <LandscapeJourney
    id="journey"
    works={home.journey.works}
    scenes={home.journey.scenes}
    copy={home.journey.copy}
  />
  <HomeCollection collection={home.collection} />
  <ExhibitionInvitation entry="home" headingId="home-exhibition-title" />
  <HomeStudioTeaser studio={home.studio} />
</SundayLayout>
