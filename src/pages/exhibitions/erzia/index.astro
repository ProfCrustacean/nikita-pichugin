---
import TourView from "../../../features/tour/TourView.astro";
import SundayLayout from "@layouts/SundayLayout.astro";

const tourJsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: "Выставка Никиты Пичугина в Музее Эрьзи",
  url: new URL("/exhibitions/erzia/", Astro.site ?? Astro.url.origin).href,
  creator: { "@type": "Person", name: "Никита Пичугин" }
};
---

<SundayLayout
  title="Выставка в Музее Эрьзи"
  description="Виртуальный проход по выставке Никиты Пичугина в Мордовском республиканском музее изобразительных искусств имени С. Д. Эрьзи."
  bodyClass="tour-page"
  noHeader
  noFooter
  jsonLd={tourJsonLd}
>
  <TourView
    frameSrc="/tours/erzia-pichugin/index.html"
    frameTitle="Виртуальный тур по выставке Никиты Пичугина в Музее Эрьзи"
    kicker="Музей Эрьзи · Саранск"
    heading={["Выставка", "Никиты Пичугина"]}
    summary="Пять панорамных точек, соединённых в выставочный маршрут."
    backHref="/"
  />
</SundayLayout>
